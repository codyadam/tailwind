FROM debian:bookworm-slim

RUN apt-get update \
	&& apt-get install -y --no-install-recommends bash curl ca-certificates jq unzip \
	&& rm -rf /var/lib/apt/lists/*

COPY deploy/github-artifact-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /opt/server
ENTRYPOINT ["/entrypoint.sh"]
